# ==============================================================================
# Verity Environment Variables
# Doc 17 §13.2 — Configuration categories
# Doc 17 §13.3 — Validated at startup via Zod
# ==============================================================================

# ──────────────────────────────────────────────────────────────────────────────
# Infrastructure (Doc 17 §13.2)
# ──────────────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ──────────────────────────────────────────────────────────────────────────────
# Database (Doc 17 §6)
# ──────────────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/verity

# ──────────────────────────────────────────────────────────────────────────────
# Authentication — Better Auth (Doc 5 §4, Doc 16 §4)
# ──────────────────────────────────────────────────────────────────────────────
SESSION_SECRET=change-me-to-a-random-string-at-least-32-chars
BETTER_AUTH_SECRET=change-me-to-a-random-string-at-least-32-chars
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# GitHub OAuth (Doc 16 §8)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ──────────────────────────────────────────────────────────────────────────────
# GitHub App — Repository Access (Doc 16 §8.5)
# ──────────────────────────────────────────────────────────────────────────────
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=

# ──────────────────────────────────────────────────────────────────────────────
# LLM Provider (Doc 13, Doc 17 §13.2)
# ──────────────────────────────────────────────────────────────────────────────
LLM_PROVIDER=mock
LLM_MODEL=claude-sonnet-4-20250514
LLM_MAX_TOKENS=8192
CLAUDE_API_KEY=

# ──────────────────────────────────────────────────────────────────────────────
# Job Queue (Doc 18 §6.1 — pg-boss uses DATABASE_URL)
# ──────────────────────────────────────────────────────────────────────────────
JOB_CONCURRENCY=5

# ──────────────────────────────────────────────────────────────────────────────
# Rate Limiting (Doc 14 §13, Doc 18 §9.4)
# ──────────────────────────────────────────────────────────────────────────────
RATE_LIMIT_STANDARD=60
RATE_LIMIT_EXPENSIVE=10

# ──────────────────────────────────────────────────────────────────────────────
# Observability (Doc 5 §7, Doc 19 §3)
# ──────────────────────────────────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=1.0

# ──────────────────────────────────────────────────────────────────────────────
# Feature Flags (Doc 17 §13.2)
# ──────────────────────────────────────────────────────────────────────────────
ENABLE_SEMANTIC_VERIFICATION=true
ENABLE_EMAIL_VERIFICATION=false
